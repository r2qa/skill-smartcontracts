# reviewing-smart-contracts — API config TEMPLATE
# ----------------------------------------------------------------------------
# Copy this to ~/.config/fearsoff/audit.env, fill in your OWN read-only keys,
# then source it from ~/.zshenv so non-interactive shells (and subagents) get it:
#
#   mkdir -p ~/.config/fearsoff
#   cp audit.env.example ~/.config/fearsoff/audit.env && chmod 600 ~/.config/fearsoff/audit.env
#   #   ...edit the file, then:
#   grep -q audit.env ~/.zshenv 2>/dev/null || \
#     echo '[ -f ~/.config/fearsoff/audit.env ] && source ~/.config/fearsoff/audit.env' >> ~/.zshenv
#
# (tooling/bootstrap.sh does this for you.) NEVER commit the filled-in file — it is
# gitignored. Keys are for READ-ONLY use only.
# ----------------------------------------------------------------------------

# TronGrid — read-only chain calls (getcontractinfo, triggerconstantcontract, eth_call,
# events) + rate-limit relief. Get a key: https://www.trongrid.io -> Dashboard -> API Keys.
#   Sent as HTTP header:  TRON-PRO-API-KEY: $TRONGRID_API_KEY
#   With a key: ~15 QPS within quota; keyless: dynamic throttling + 403 bans.
export TRONGRID_API_KEY=""

# TronScan — verified SOURCE fetch (used by get-source.sh via POST /api/solidity/contract/info)
# + rich metadata. Get a key: https://tronscan.org/#/myaccount/apiKeys
#   Sent as HTTP header:  TRON-PRO-API-KEY: $TRONSCAN_API_KEY
#   Keyless TronScan is unreliable/stripped since 2025-08-31.
export TRONSCAN_API_KEY=""

# Endpoints (mainnet / nile testnet / shasta testnet)
export TRONGRID_MAINNET="https://api.trongrid.io"
export TRONGRID_NILE="https://nile.trongrid.io"
export TRONGRID_SHASTA="https://api.shasta.trongrid.io"
export TRONSCAN_API="https://apilist.tronscanapi.com"

# panoramix needs a web3 RPC to decompile by address (optional)
export WEB3_PROVIDER_URI=""
